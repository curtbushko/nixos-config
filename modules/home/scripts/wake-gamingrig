#!/usr/bin/env bash
set -euo pipefail

GAMINGRIG="gamingrig"
RELAY="${RELAY_TAILNET_ID:-relay}"
CURRENT_HOST="$(hostname -s)"

function logger() {
	local TYPE=$1
	shift
	local MESSAGE="$*"
	local TIMESTAMP
	TIMESTAMP=$(date +"%Y-%m-%dT%H:%M:%SZ")
	echo "[$TIMESTAMP] [$TYPE] $MESSAGE"
}

# Read MAC address from environment or sops secrets file
MAC_ADDRESS="${GAMINGRIG_MAC_ADDRESS:-}"
if [ -z "$MAC_ADDRESS" ] && [ -f "/run/secrets/secrets.env" ]; then
	# shellcheck disable=SC1091
	source /run/secrets/secrets.env
	MAC_ADDRESS="${GAMINGRIG_MAC_ADDRESS:-}"
fi

# Check if gamingrig is already up
if ping -c 1 -W 2 "$GAMINGRIG" &>/dev/null; then
	logger INFO "Gamingrig is already up"
	exit 0
fi

# Validate MAC address is available
if [ -z "$MAC_ADDRESS" ]; then
	logger ERROR "GAMINGRIG_MAC_ADDRESS not set in environment or secrets file"
	exit 1
fi

# Wake gamingrig using host-specific method
case "$CURRENT_HOST" in
	curtbushko-X3FR7279D2|curtbushko-K4W6XK6XND|jackson-m1pro|m1-pro)
		# On LAN - use wakeonlan directly
		logger INFO "Waking gamingrig (LAN)..."
		wakeonlan "$MAC_ADDRESS" 2>/dev/null || true
		;;
	m4-pro|m1-air)
		# Remote - bounce off relay via Tailscale
		logger INFO "Waking gamingrig via $RELAY (Tailscale)..."
		ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no \
			root@"$RELAY" "etherwake -D -i eth0 '$MAC_ADDRESS'" 2>/dev/null || true
		;;
	node00|node01|node02|gamingrig-vm)
		# Linux servers - bounce off relay
		logger INFO "Waking gamingrig via $RELAY..."
		ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no \
			root@"$RELAY" "etherwake -D -i eth0 '$MAC_ADDRESS'" 2>/dev/null || true
		;;
	*)
		logger ERROR "Unknown host: $CURRENT_HOST"
		exit 1
		;;
esac

# Wait for gamingrig to come up (max 60 seconds)
logger INFO "Waiting for gamingrig to respond..."
for i in {1..30}; do
	if ping -c 1 -W 2 "$GAMINGRIG" &>/dev/null; then
		logger INFO "Gamingrig is up"
		exit 0
	fi
	sleep 2
done

logger WARN "Gamingrig did not respond after wake attempt"
exit 1
